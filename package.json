  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "rm -f .next/lock",
    "build": "next build",
    "start": "next start",
    "prestart": "./scripts/agent_startup_check.sh",
    "predev": "./scripts/agent_startup_check.sh",
    "lint": "npx @biomejs/biome check . && next lint",
    "lint:fix": "npx @biomejs/biome check --write .",
    "lint:ci": "npx @biomejs/biome ci .",
    "format": "npx @biomejs/biome format --write .",
    "lint:eslint": "eslint .",
    "ws:dev": "npx ts-node --project tsconfig.server.json backend/websocket/server.ts",
    "services:dev": "pm2 start ecosystem.config.js",
    "services:stop": "pm2 stop all",
    "test:websocket": "npx ts-node scripts/test-websocket-connection.ts",
    "test:trading-e2e": "npx ts-node scripts/test-trading-e2e.ts",
    "test:institutional-features": "npx ts-node scripts/test-institutional-features.ts",
    "test:signal-generation": "npx ts-node scripts/test-signal-generation.ts",
    "test:mfa-flow": "npx ts-node scripts/test-mfa-flow.ts",
    "test:security": "vitest run scripts/security-test.ts --config=vitest.security.config.ts",
    "cleanup:audit-logs": "./scripts/cleanup-audit-logs.sh",
    "test": "vitest run",
    "semantic-release": "semantic-release",
    "prepare": "husky || true"
  },
